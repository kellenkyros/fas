---
name: fas
services:
  frontend:
    build:
      context: ../../fas/frontend
      dockerfile: Dockerfile
    container_name: fas-frontend
    volumes:
      - "../../fas/frontend:/app"
      - "/app/node_modules"
    ports:
      - "5173:5173"
    environment:
      - VITE_API_URL=http://localhost:3000
